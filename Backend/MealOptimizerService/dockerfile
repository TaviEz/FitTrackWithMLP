# 1. Use a lightweight Python base image
FROM python:3.12-slim

# 2. Set the working directory inside the container
WORKDIR /app

# 3. Copy only the requirements first (to cache the installation layer)
COPY /MealOptimizerService/requirements.txt .

# 4. Install dependencies
RUN pip install --no-cache-dir -r requirements.txt

# 5. Copy the rest of your application code
COPY MealOptimizerService/ .

# 6. Expose the port FastAPI runs on
EXPOSE 8080

# 7. Start the Uvicorn server
# We use the same path notation as your debugger
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]